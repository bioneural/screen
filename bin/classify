#!/usr/bin/env ruby
# bin/classify — classify input against a condition via LLM
# MIT License — Copyright (c) 2026 Kerry Ivan Kurian
#
# Reads JSON from stdin:
#   { "condition": "...", "model": "claude-haiku-4-5-20251001",
#     "file_path": "...", "command": "...", "prompt": "...", "content": "..." }
#
# Prints "yes" or "no" to stdout. Exits 0 on success, 1 on failure.
# With --score flag, prints the numeric confidence score (0.0-1.0) instead.
#
# Dependencies: ruby stdlib, ANTHROPIC_API_KEY

require_relative '../lib/classifier'
require 'json'
require 'open3'

score_mode = ARGV.delete('--score')

SPILL_HOME = ENV['SPILL_HOME'] || File.expand_path('../../spill', __dir__)
if File.directory?(SPILL_HOME)
  require File.join(SPILL_HOME, 'lib', 'spill')
  Spill.configure(tool: 'classify')
end

if ARGV.first == 'doctor'
  report = {}

  report['ruby'] = { 'version' => RUBY_VERSION, 'ok' => true }

  # Classifier library
  report['classifier_lib'] = { 'ok' => defined?(CLASSIFIER_MODEL) ? true : true }

  # Anthropic API key
  has_key = !ANTHROPIC_API_KEY.nil? && !ANTHROPIC_API_KEY.empty?
  report['anthropic_api_key'] = { 'ok' => has_key }
  report['anthropic_api_key']['error'] = 'ANTHROPIC_API_KEY not set' unless has_key

  # Spill loadable
  report['spill'] = { 'path' => SPILL_HOME, 'ok' => defined?(Spill) ? true : false }

  # Probe
  if ARGV.include?('--probe')
    if has_key
      begin
        input = JSON.generate({ 'condition' => 'Is 2+2 equal to 4?', 'content' => '2+2 = 4' })
        output, status = Open3.capture2('ruby', __FILE__, stdin_data: input, err: File::NULL)
        answer = output.strip.downcase
        valid = %w[yes no].include?(answer)
        report['probe'] = { 'ok' => true, 'answer' => answer }
        report['probe']['warn'] = "expected yes or no, got: #{answer}" unless valid
      rescue => e
        report['probe'] = { 'ok' => true, 'warn' => "probe error: #{e.message}" }
      end
    else
      report['probe'] = { 'ok' => true, 'skipped' => 'ANTHROPIC_API_KEY not set' }
    end
  end

  report['protocol_version'] = 1
  report['ok'] = report.values.all? { |v| v.is_a?(Hash) ? v['ok'] != false : true }
  puts JSON.pretty_generate(report)
  exit(report['ok'] ? 0 : 1)
end

input = JSON.parse($stdin.read)
condition = input.delete('condition')
model = input.delete('model') || CLASSIFIER_MODEL

fields = build_classifier_input(input)
if fields.empty?
  defined?(Spill) ? Spill.error("no input fields provided") : $stderr.puts("classify: no input fields provided")
  exit 1
end

prompt = CLASSIFIER_TEMPLATE % { condition: condition, fields: fields }

result = classify_with_anthropic(prompt, model)

if result
  if score_mode
    puts format('%.3f', result[:score])
  else
    puts result[:answer]
  end
else
  defined?(Spill) ? Spill.error("classification failed") : $stderr.puts("classify: classification failed")
  exit 1
end
